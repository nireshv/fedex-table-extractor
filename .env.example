# Copy this file to .env and fill in your values

# LLM provider: "anthropic" or "openai"
# LLM_PROVIDER=anthropic
LLM_PROVIDER=openai

# Model name (provider-specific)
# Anthropic: claude-sonnet-4-6, claude-opus-4-6, claude-haiku-4-5-20251001
# OpenAI: gpt-4o, gpt-4o-mini
# LLM_MODEL=claude-sonnet-4-6
LLM_MODEL=gpt-5

# API keys (only the one matching LLM_PROVIDER is required)
# ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# Paths
PDF_PATH=table_full.pdf
DB_PATH=fedex_rates.db

# Pipeline settings
# parallel pages in parallel mode
CONCURRENCY=5
# LLM call retries on failure
MAX_RETRIES=3
# base wait between retries (exponential backoff)
RETRY_WAIT_SECONDS=2.0
# rows per SQLite executemany batch
BATCH_SIZE=100
# keep deterministic
LLM_TEMPERATURE=0.0
