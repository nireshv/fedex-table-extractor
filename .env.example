# Copy this file to .env and fill in your values

# LLM provider: "anthropic" or "openai"
LLM_PROVIDER=anthropic

# Model name (provider-specific)
# Anthropic: claude-sonnet-4-6, claude-opus-4-6, claude-haiku-4-5-20251001
# OpenAI: gpt-4o, gpt-4o-mini
LLM_MODEL=claude-sonnet-4-6

# API keys (only the one matching LLM_PROVIDER is required)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# Paths
PDF_PATH=table_full.pdf
DB_PATH=fedex_rates.db

# Pipeline settings
CONCURRENCY=5          # parallel pages in parallel mode
MAX_RETRIES=3          # LLM call retries on failure
RETRY_WAIT_SECONDS=2.0 # base wait between retries (exponential backoff)
BATCH_SIZE=100         # rows per SQLite executemany batch
LLM_TEMPERATURE=0.0    # keep deterministic
